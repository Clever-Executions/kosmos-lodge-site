---
import Layout from '../components/Layout.astro';
import { sanityClient } from 'sanity:client';
import { HOME_DATA_QUERY } from '../utils/queries';
import { urlFor, activityImage } from '../utils/sanity';
import { galleryFallback } from '../utils/galleryFallback';
import { BUSINESS, faqJsonLd } from '../utils/seo';

const { page, settings, rooms, activities } = await sanityClient.fetch(HOME_DATA_QUERY);
const wa = settings?.whatsapp ?? BUSINESS.whatsapp;
const address = settings?.address ?? BUSINESS.address.full;
const mapsUrl = settings?.mapsUrl ?? BUSINESS.mapsUrl;

// "Life at Kosmos Lodge" gallery: use Sanity images if set, otherwise fall back
// to a random selection of the bundled lodge photos.
const sanityGallery = (page?.galleryImages ?? []) as any[];
const galleryUrls: string[] = sanityGallery.length
  ? sanityGallery.map((img) => urlFor(img).width(400).height(300).url())
  : galleryFallback(9);

// Guest reviews / social proof.
// Live Google figures (Kosmos Lodge on Google Maps: 4.5★ from 128 reviews) and a
// set of real 5-star guest reviews act as the fallback. Anything set on the
// homePage document in Sanity wins, so the lodge can edit all of this in Studio
// without a code change — and leaving it blank keeps these sensible defaults.
const FALLBACK_REVIEWS = [
  { quote: 'One of the best locations around the dam — luxurious rooms and friendly staff. Highly recommend!', author: 'Zack de Beer', context: 'Couple · Holiday', rating: 5 },
  { quote: 'Amazing views, luxurious rooms and great hosts. The views of the dam from the balcony are amazing and the owner is very professional and helpful.', author: 'Matilda Twala', context: 'Google review', rating: 5 },
  { quote: 'Beautiful place! Choose the upstairs balcony room for a view over the dam to die for.', author: 'Esther R', context: 'Google review', rating: 5 },
  { quote: 'The reservation process was extremely quick and easy, and the room and bathroom are modern and spotlessly clean.', author: 'Kirstan', context: 'Google review', rating: 5 },
  { quote: 'The rooms were beautiful, but the best of all was the location and the great views over the dam.', author: 'Liesie', context: 'Google review', rating: 5 },
  { quote: 'A true 5-star experience — modern, clean and peaceful, with a wonderful atmosphere.', author: 'Karin W', context: 'Google review', rating: 5 },
  { quote: 'Beautiful and luxurious room with the most breathtaking views over the dam. The best views in town!', author: 'Eemblond Tours', context: 'Google review', rating: 5 },
];

const reviewsLabel = page?.reviewsLabel ?? 'Guest Reviews';
const reviewsHeading = page?.reviewsHeading ?? 'Loved by Our Guests';
const reviewsIntro = page?.reviewsIntro ?? 'Real words from guests who have woken up to the Hartbeespoort Dam from their balcony.';
const googleRating = page?.googleRating ?? 4.5;
const googleReviewCount = page?.googleReviewCount ?? 128;
const yearsOperating = page?.yearsOperating ?? 11;
const googleReviewsUrl = page?.googleReviewsUrl ?? mapsUrl;
const reviewItems = (page?.reviews?.length ? page.reviews : FALLBACK_REVIEWS) as any[];
// Duplicate the track so the marquee loops seamlessly. Render at least 6 cards
// before duplicating so short lists still fill the row.
const marqueeReviews = [...reviewItems, ...reviewItems];
// Full / half / empty stars for the headline rating.
const fullStars = Math.floor(googleRating);
const hasHalfStar = googleRating - fullStars >= 0.25 && googleRating - fullStars < 0.75;
const roundUp = googleRating - fullStars >= 0.75;

// FAQ content — answers the questions guests (and AI assistants) actually ask,
// loaded with the keywords and the couples/luxury positioning we want to rank for.
const faqs = [
  {
    q: 'Where is Kosmos Lodge located in Hartbeespoort?',
    a: 'Kosmos Lodge is in Kosmos Village, a secure, boomed-off area on the slopes of the Magaliesberg overlooking the Hartbeespoort Dam, at 121 Paul Kruger Avenue, Kosmos, Hartbeespoort, 0261. It is roughly a 45-minute drive from Pretoria and about an hour from Johannesburg and OR Tambo International Airport.',
  },
  {
    q: 'Is Kosmos Lodge a good guesthouse for couples and romantic getaways?',
    a: 'Yes. Kosmos Lodge is an intimate, adults-focused luxury guesthouse built for romance and privacy. With only seven individually styled rooms, sweeping dam views and quiet, exclusive surroundings, it is ideally suited to couples seeking a romantic weekend getaway in Hartbeespoort rather than large groups or party crowds.',
  },
  {
    q: 'How much does it cost to stay at Kosmos Lodge?',
    a: 'Rooms range from approximately R1,000 to R2,700 per room per night depending on the room, the dates and the number of guests. Contact us directly on WhatsApp or by email for current rates and our best available offers.',
  },
  {
    q: 'What is there to do near Kosmos Lodge in Hartbeespoort?',
    a: 'Hartbeespoort is one of Gauteng’s favourite weekend escapes. Within minutes of the lodge you can enjoy the Hartbeespoort Cableway, hot-air ballooning over the valley, the Elephant Sanctuary, dam boat cruises, the Welwitschia waterfront, fine dining and Magaliesberg hiking trails.',
  },
  {
    q: 'Does Kosmos Lodge have dam views, WiFi and en-suite rooms?',
    a: 'Yes. Every room is en-suite and most enjoy views over the Hartbeespoort Dam. The lodge offers free WiFi, DStv, air-conditioning, private balconies and secure parking inside the gated Kosmos Village.',
  },
  {
    q: 'Is Kosmos Lodge suitable for large groups or children?',
    a: 'Kosmos Lodge is a small, exclusive retreat best suited to couples and discerning adult travellers who value tranquillity and privacy. It is not designed for large group functions or busy family stays, which keeps the atmosphere refined and peaceful.',
  },
];
---
<Layout
  title="Kosmos Lodge | Luxury Guesthouse in Hartbeespoort with Dam Views"
  description="Kosmos Lodge is an exclusive luxury guesthouse in Hartbeespoort, overlooking the Hartbeespoort Dam. Seven individually styled rooms, dam views and 5-star hospitality — the perfect romantic getaway for couples in the Magaliesberg."
  navActive="home"
  jsonLd={[faqJsonLd(faqs)]}
>

  <!-- Hero -->
  <section class="hero" id="top">
    <div class="hero-bg" style={`background-image:url('${page?.heroImage ? urlFor(page.heroImage).width(1920).url() : '/assets/images/hero-bg.jpg'}')`}></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 set:html={page?.heroHeading ? page.heroHeading.replace(/\\n/g, '<br>') : 'Where Luxury Meets<br><em>The Dam Views</em>'}></h1>
      <p>{page?.heroSubheading ?? 'Spend a luxurious weekend in an exclusive little private lodge, situated in the Magaliesberg mountain village of Kosmos, overlooking the Hartbeespoort Dam.'}</p>
      <div class="hero-actions">
        <a href="/rooms" class="btn btn-primary"><i class="fas fa-bed"></i> View Rooms</a>
        <a href="/#contact" class="btn btn-outline"><i class="fas fa-paper-plane"></i> Get in Touch</a>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll</span>
      <i class="fas fa-chevron-down"></i>
    </div>
  </section>

  <!-- Features Strip -->
  <div class="features-strip">
    <div class="features-grid container">
      {(page?.features ?? []).map((f: any) => (
        <div class="feature-card fade-up">
          <div class="feature-icon"><i class={f.icon}></i></div>
          <h4>{f.heading}</h4>
          <p>{f.subtext}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Rooms Preview -->
  <section class="rooms-section" id="rooms">
    <div class="container">
      <div class="section-header">
        <div class="left">
          <div class="section-label light">Accommodation</div>
          <h2>Our Rooms</h2>
          <p>{page?.roomsSectionIntro ?? 'Seven individually styled rooms, each offering comfort, quality and unforgettable views of the Hartbeespoort Dam.'}</p>
        </div>
        <a href="/rooms" class="btn btn-ghost">View All Rooms <i class="fas fa-arrow-right"></i></a>
      </div>
      <div class="rooms-grid">
        {/* Show six rooms here (two clean rows); the full seven live on /rooms. */}
        {(rooms ?? []).slice(0, 6).map((room: any) => (
          <div class="room-card fade-up">
            <div class="room-card-img">
              {room.cardImage
                ? <img src={urlFor(room.cardImage).width(600).height(400).url()} alt={room.name}>
                : <img src={`/assets/images/rooms/${room.name?.replace(' ', '_')}-card.jpg`} alt={room.name}>}
              <span class="room-badge">{room.name}</span>
              <div class="room-stars">
                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
              </div>
            </div>
            <div class="room-card-body">
              <h3>{room.heroHeading}</h3>
              <p>{room.tagline}</p>
              <div class="room-card-footer">
                <div class="room-tags">
                  {(room.cardTags ?? []).map((tag: any) => (
                    <span class="room-tag"><i class={tag.icon}></i> {tag.label}</span>
                  ))}
                </div>
                <a href={`/rooms/${room.slug?.current}`} class="btn btn-ghost btn-sm">View</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Guest Reviews / Social Proof -->
  <section class="reviews-section" id="reviews">
    <div class="container">
      <div class="reviews-head">
        <div class="section-label light" style="justify-content:center">{reviewsLabel}</div>
        <h2>{reviewsHeading}</h2>
        <p class="reviews-intro">{reviewsIntro}</p>
      </div>

      <div class="reviews-stats">
        <a class="review-stat review-stat--link" href={googleReviewsUrl} target="_blank" rel="noopener" aria-label={`${googleRating} out of 5 from ${googleReviewCount} Google reviews`}>
          <div class="review-stat-figure">{googleRating}</div>
          <div class="review-stat-stars" aria-hidden="true">
            {Array.from({ length: fullStars }).map(() => <i class="fas fa-star"></i>)}
            {hasHalfStar && <i class="fas fa-star-half-alt"></i>}
            {Array.from({ length: 5 - fullStars - (hasHalfStar ? 1 : 0) - (roundUp ? 1 : 0) }).map(() => <i class="far fa-star"></i>)}
            {roundUp && <i class="fas fa-star"></i>}
          </div>
          <div class="review-stat-label"><i class="fab fa-google"></i> Rated on Google</div>
        </a>
        <div class="review-stat">
          <div class="review-stat-figure">{googleReviewCount}<span class="review-stat-plus">+</span></div>
          <div class="review-stat-sub">Guest Reviews</div>
          <div class="review-stat-label">Verified across Google &amp; travel sites</div>
        </div>
        <div class="review-stat">
          <div class="review-stat-figure">{yearsOperating}</div>
          <div class="review-stat-sub">Years of Hospitality</div>
          <div class="review-stat-label">Welcoming guests since {page?.establishedYear ?? (2026 - yearsOperating)}</div>
        </div>
      </div>

      <div class="reviews-marquee">
        <div class="reviews-track">
          {marqueeReviews.map((r: any, i: number) => (
            <figure class="review-card" aria-hidden={i >= reviewItems.length ? 'true' : undefined}>
              <div class="review-card-stars" aria-hidden="true">
                {Array.from({ length: r.rating ?? 5 }).map(() => <i class="fas fa-star"></i>)}
              </div>
              <blockquote class="review-card-quote">{r.quote}</blockquote>
              <figcaption class="review-card-author">
                <span class="review-card-avatar">{(r.author ?? '?').trim().charAt(0).toUpperCase()}</span>
                <span class="review-card-meta">
                  <span class="review-card-name">{r.author}</span>
                  {r.context && <span class="review-card-context">{r.context}</span>}
                </span>
                <i class="fab fa-google review-card-source" title="Google review"></i>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Gallery -->
  <section class="gallery-section" id="gallery">
    <div class="container">
      <div class="section-label">The Lodge</div>
      <h2>Life at Kosmos Lodge</h2>
      <p class="gallery-intro">A glimpse of our beautiful property and the stunning Hartbeespoort setting.</p>
      <div class="gallery-grid">
        {galleryUrls.map((src: string) => (
          <div class="gallery-item fade-up">
            <img src={src} alt="Kosmos Lodge" loading="lazy">
            <div class="gallery-overlay"><i class="fas fa-expand-alt"></i></div>
          </div>
        ))}
      </div>
      <div class="gallery-footer">
        <a href="/#contact" class="btn btn-ghost"><i class="fas fa-images"></i> Book Your Stay</a>
      </div>
    </div>
  </section>

  <!-- About Section / Our Story -->
  <section class="about-section" id="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-image-stack fade-up">
          <div class="about-img-main">
            {page?.aboutMainImage
              ? <img src={urlFor(page.aboutMainImage).width(600).url()} alt="Kosmos Lodge view">
              : <img src="/assets/images/gallery/IMG_5839.jpg" alt="Kosmos Lodge view">}
          </div>
          <div class="about-img-accent">
            {page?.aboutAccentImage
              ? <img src={urlFor(page.aboutAccentImage).width(300).url()} alt="Lodge detail">
              : <img src="/assets/images/gallery/IMG_5812.jpg" alt="Lodge detail">}
          </div>
          <div class="about-stat">
            <span class="num">{page?.establishedYear ?? 2015}</span>
            <span class="lbl">Est.</span>
          </div>
        </div>
        <div class="about-text fade-up">
          <div class="section-label">{page?.aboutLabel ?? 'Our Story'}</div>
          <h2>{page?.aboutHeading ?? "Traveller's Choice in Hartbeespoort"}</h2>
          {(page?.aboutParagraphs ?? []).map((p: string) => <p>{p}</p>)}
          <div class="accordion-list">
            {(page?.accordionItems ?? []).map((item: any) => (
              <div class="accordion-item">
                <button class="accordion-trigger">
                  {item.title}
                  <span class="accordion-icon"><i class="fas fa-chevron-down"></i></span>
                </button>
                <div class="accordion-body">
                  <div class="accordion-body-inner">{item.body}</div>
                </div>
              </div>
            ))}
          </div>
          <a href="/#contact" class="btn btn-primary">
            <i class="fas fa-paper-plane"></i> Get in Touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Explore Preview -->
  <section class="explore-section" id="explore">
    <div class="container">
      <div class="section-header">
        <div class="left">
          <div class="section-label light">Around Us</div>
          <h2>Eat, Explore &amp; Experience</h2>
          <p>Hartbeespoort offers world-class attractions just minutes from your room.</p>
        </div>
        <a href="/explore" class="btn btn-ghost">All Attractions <i class="fas fa-arrow-right"></i></a>
      </div>
      <div class="explore-grid">
        {(activities ?? []).slice(0, 6).map((act: any, i: number) => {
          const cardImg = activityImage(act, ['cardImage', 'mainImage'], { width: 600, height: 400 });
          return (
          <div class="explore-card fade-up">
            {cardImg && <img src={cardImg} alt={act.name}>}
            <div class="explore-overlay">
              <span class="explore-num">No.{act.order ?? i + 1}</span>
              <h3>{act.name}</h3>
              <p>{act.cardSummary ?? (act.paragraphs?.[0] ?? '').substring(0, 120)}</p>
              <a href={`/explore/${act.slug?.current}`} class="explore-link">Learn More <i class="fas fa-arrow-right"></i></a>
            </div>
          </div>
          );})}
      </div>
    </div>
  </section>

  <!-- Awards Section -->
  {page?.awards?.length > 0 && (
    <section class="awards-section">
      <div class="container">
        <div class="section-inner">
          <div class="section-label" style="justify-content:center">Recognition</div>
          <h2>Accommodation Awards</h2>
          <p class="sub">Trusted and recognised by leading travel platforms worldwide.</p>
        </div>
        <div class="awards-grid">
          {page.awards.map((award: any) => (
            <div class="award-item fade-up">
              <img src={urlFor(award).url()} alt="Award">
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Location / Find Us -->
  <section class="location-section" id="location">
    <div class="container">
      <div class="section-header">
        <div class="left">
          <div class="section-label">Find Us</div>
          <h2>Our Location in Hartbeespoort</h2>
          <p>Tucked into the secure village of Kosmos on the slopes of the Magaliesberg, overlooking the Hartbeespoort Dam — about 45 minutes from Pretoria and an hour from Johannesburg.</p>
        </div>
      </div>
      <div class="location-grid">
        <div class="location-map fade-up">
          <iframe
            src={BUSINESS.mapsEmbedUrl}
            title="Map showing Kosmos Lodge, Kosmos, Hartbeespoort"
            width="100%" height="100%" style="border:0;"
            loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen></iframe>
        </div>
        <div class="location-info fade-up">
          <h3>Kosmos Lodge</h3>
          <p class="location-address">
            <i class="fas fa-map-marker-alt"></i>
            <span>{address}</span>
          </p>
          <p class="location-note">
            Set inside a boomed-off, secure estate, Kosmos Lodge offers the privacy and
            tranquillity of an exclusive dam-side retreat while keeping Hartbeespoort’s
            best restaurants, the Cableway and the waterfront just minutes away.
          </p>
          <div class="location-actions">
            <a href={mapsUrl} target="_blank" rel="noopener" class="btn btn-primary">
              <i class="fas fa-map-marked-alt"></i> View on Google Maps
            </a>
            <a href={BUSINESS.mapsDirectionsUrl} target="_blank" rel="noopener" class="btn btn-ghost">
              <i class="fas fa-route"></i> Get Directions
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section" id="faq">
    <div class="container">
      <div class="section-inner" style="text-align:center;max-width:720px;margin:0 auto 2.5rem;">
        <div class="section-label" style="justify-content:center">Good to Know</div>
        <h2>Frequently Asked Questions</h2>
        <p class="sub">Everything you need to know about staying at our luxury guesthouse in Hartbeespoort.</p>
      </div>
      <div class="faq-list">
        {faqs.map((f) => (
          <div class="accordion-item">
            <button class="accordion-trigger">
              {f.q}
              <span class="accordion-icon"><i class="fas fa-chevron-down"></i></span>
            </button>
            <div class="accordion-body">
              <div class="accordion-body-inner">{f.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section" id="contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-form-wrap">
          <div class="section-label light">Contact</div>
          <h2>Let's Get in Touch</h2>
          <p>Ready to book your stay or have questions? We'd love to hear from you.</p>
          <form class="contact-form" action={settings?.formspreeUrl ?? 'https://formspree.io/f/mkoeeorg'} method="post">
            <div class="form-row">
              <div class="form-group">
                <label>Your Name *</label>
                <input type="text" name="name" placeholder="John Smith" required>
              </div>
              <div class="form-group">
                <label>Email Address *</label>
                <input type="email" name="email" placeholder="john@example.com" required>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Phone Number</label>
                <input type="tel" name="phone" placeholder="+27 XX XXX XXXX">
              </div>
              <div class="form-group">
                <label>Subject *</label>
                <input type="text" name="subject" placeholder="Booking enquiry" required>
              </div>
            </div>
            <div class="form-group">
              <label>Message *</label>
              <textarea name="message" placeholder="Tell us about your planned stay, preferred dates, number of guests..." required></textarea>
            </div>
            <button type="submit" class="btn btn-primary">
              <i class="fas fa-paper-plane"></i> Send Message
            </button>
          </form>
        </div>
        <div class="contact-info">
          <div class="contact-card">
            <h3>Contact Details</h3>
            <div class="contact-detail">
              <div class="contact-icon"><i class="fas fa-phone"></i></div>
              <div class="contact-detail-text">
                <label>Phone Number</label>
                <span>{settings?.phone ?? '+27 78 887 2882'}</span>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-icon"><i class="fas fa-envelope"></i></div>
              <div class="contact-detail-text">
                <label>Email Address</label>
                <span>{settings?.email ?? 'lodge@kosmoslodge.co.za'}</span>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-icon"><i class="fas fa-map-marker-alt"></i></div>
              <div class="contact-detail-text">
                <label>Address</label>
                <span>{settings?.address ?? '121 Paul Kruger Ave, Kosmos, Hartbeespoort, 0261'}</span>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-icon"><i class="fas fa-globe"></i></div>
              <div class="contact-detail-text">
                <label>Website</label>
                <span>www.kosmoslodge.co.za</span>
              </div>
            </div>
            <div class="contact-social">
              <a href={`https://wa.me/${wa}`} target="_blank" title="WhatsApp"><i class="fab fa-whatsapp"></i></a>
              <a href={`mailto:${settings?.email ?? 'lodge@kosmoslodge.co.za'}`} title="Email"><i class="fas fa-envelope"></i></a>
              <a href={settings?.facebookUrl ?? 'https://www.facebook.com/kosmoslodge'} target="_blank" title="Facebook"><i class="fab fa-facebook-f"></i></a>
            </div>
          </div>
          <div class="rate-card">
            <h3>{settings?.rateCardText ?? 'R1,000 - R2,700'}</h3>
            <p>{settings?.rateCardSubtext ?? 'Per room per night, depending on room type, dates and number of guests. Enquire for best rates.'}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
